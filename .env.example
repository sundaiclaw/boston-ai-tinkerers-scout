# Server port for the stateless Express app.
PORT=8080

# Optional OpenRouter API key. Leave blank to use deterministic fallback mode.
OPENROUTER_API_KEY=

# Optional OpenRouter settings.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemma-3-27b-it:free
OPENROUTER_SITE_NAME=Boston AI Tinkerers
OPENROUTER_SITE_URL=

# Keep this true unless you explicitly want AI routes to fail when OpenRouter is unavailable.
ALLOW_FALLBACK_AI=true
